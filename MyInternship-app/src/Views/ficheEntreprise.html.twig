{% extends "base/mise-en-page.html.twig" %}

{% block pageTitle %}
    <title>{{ entreprise.Nom_Entreprise }} - MyInternship</title>
{% endblock %}

{% block content %}
    <div class="container">
        <div class="section">
            <div class="card">
                <div class="company-card__top">
                    <h1>{{ entreprise.Nom_Entreprise }}</h1>
                    <p class="company-note">{{ note }}/5</p>
                    {% if affichageBoutons %}
                        <div class="company-actions">
                            <a class="btn btn--primary" href="?route=entreprise_edit&id={{ entreprise.Id_Entreprise }}">Modifier</a>
                            <a class="btn btn--primary" style="background-color: red; border-color: red" href="?route=entreprise_delete&id={{ entreprise.Id_Entreprise }}" onclick="return confirm('Êtes-vous sûr de vouloir supprimer cette entreprise ?');">Supprimer</a>
                        </div>
                    {% endif %}
                </div>
                <p class="muted">Siège social : {{ entreprise.Nom_Adresse }}, {{ entreprise.Nom_Ville }}, {{ entreprise.Nom_Pays }}</p>

                <p>{{ entreprise.Description_Entreprise }}</p>

                <h2>Contact</h2>
                <p>Email : {{ entreprise.Email }}</p>
                <p>Numéro de Téléphone : {{ entreprise.Telephone }}</p>

                <h2>Liste des offres de stages proposées par l'entreprise :</h2>
                <div class="list">
                    {% for offre in offres %}
                        <div class="list__item">
                            <div class="list__title">{{ offre.Titre }}</div>
                            <a class="btn btn--small" href="?route=internship_show&id={{ offre.Id_Offre }}">Voir</a>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
