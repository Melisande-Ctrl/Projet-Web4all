{% extends 'base/mise-en-page.html.twig' %}

{% block pageTitle %}
<title>{{ page_title }}</title>
{% endblock %}

{% block content %}
<section class="section">
    <div class="container narrow">
        {% if offre %}
            <article class="card offer-card">
                <a class="link" href="?route=offres_stage">Retour a la liste des offres</a>

                <h1>{{ offre.title }}</h1>

                <div class="list__meta">
                    <span>{{ offre.company }}</span>
                    <span>{{ offre.location }}</span>
                    <span>{{ offre.duration_weeks }} semaines</span>
                    {% if offre.salary %}
                        <span>{{ offre.salary }}</span>
                    {% endif %}
                    <span>Publiee le {{ offre.created_at }}</span>
                </div>

                <div class="offer-card__section">
                    <h2>Description</h2>
                    <p>{{ offre.description }}</p>
                </div>

                <div class="offer-card__section">
                    <h2>Localisation</h2>
                    <p>{{ offre.address }}, {{ offre.location }}{% if offre.country %}, {{ offre.country }}{% endif %}</p>
                </div>

                <div class="offer-card__section">
                    <h2>Competences recherchees</h2>
                    {% if offre.skills is not empty %}
                        <ul class="tag-list">
                            {% for competence in offre.skills %}
                                <li class="badge">{{ competence }}</li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <p class="muted">Aucune competence n est encore renseignee pour cette offre.</p>
                    {% endif %}
                </div>
            </article>
        {% else %}
            <article class="card empty-state">
                <h1>Offre introuvable</h1>
                <p class="muted">L identifiant de l offre est absent, invalide, ou l offre n existe plus en base.</p>
                <a class="btn btn--ghost" href="?route=offres_stage">Retour aux offres</a>
            </article>
        {% endif %}
    </div>
</section>
{% endblock %}
