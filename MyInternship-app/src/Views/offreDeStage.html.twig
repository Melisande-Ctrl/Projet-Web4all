{% extends 'base/layout.html.twig' %}

{% block pageTitle %}
<title>{{ page_title }}</title>
{% endblock %}

{% block content %}
<section class="section">
    <div class="container narrow">
        {% if offer %}
            <article class="card offer-card">
                <a class="link" href="?route=internships">Retour a la liste des offres</a>

                <h1>{{ offer.title }}</h1>

                <div class="list__meta">
                    <span>{{ offer.company }}</span>
                    <span>{{ offer.location }}</span>
                    <span>{{ offer.duration_weeks }} semaines</span>
                    {% if offer.salary %}
                        <span>{{ offer.salary }}</span>
                    {% endif %}
                    <span>Publiee le {{ offer.created_at }}</span>
                </div>

                <div class="offer-card__section">
                    <h2>Description</h2>
                    <p>{{ offer.description }}</p>
                </div>

                <div class="offer-card__section">
                    <h2>Localisation</h2>
                    <p>{{ offer.address }}, {{ offer.location }}{% if offer.country %}, {{ offer.country }}{% endif %}</p>
                </div>

                <div class="offer-card__section">
                    <h2>Competences recherchees</h2>
                    {% if offer.skills is not empty %}
                        <ul class="tag-list">
                            {% for skill in offer.skills %}
                                <li class="badge">{{ skill }}</li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <p class="muted">Aucune competence n est encore renseignee pour cette offre.</p>
                    {% endif %}
                </div>
            </article>
        {% else %}
            <article class="card empty-state">
                <h1>Offre introuvable</h1>
                <p class="muted">L identifiant de l offre est absent, invalide, ou l offre n existe plus en base.</p>
                <a class="btn btn--ghost" href="?route=internships">Retour aux offres</a>
            </article>
        {% endif %}
    </div>
</section>
{% endblock %}
