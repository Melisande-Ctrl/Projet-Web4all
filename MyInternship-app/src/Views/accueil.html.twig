{% extends 'base/mise-en-page.html.twig' %}

{% block pageTitle %}
<title>{{ page_title }}</title>
{% endblock %}

{% block content %}
<section class="hero">
    <div class="container hero__grid">
        <div class="hero__copy">
            <p class="hero__eyebrow">Plateforme scolaire de recherche de stage</p>
            <h1>Trouvez un <span class="accent">stage</span> adapté à votre profil.</h1>
            <p class="muted hero__lead">
                MyInternship aide les étudiants à repérer les meilleures opportunités, à comparer les entreprises,
                à suivre les candidatures et à avancer plus vite avec l’accompagnement des pilotes.
            </p>

            <div class="hero__actions">
                <a class="btn btn--primary" href="?route=offres_stage">Trouver un stage</a>
                <a class="btn btn--ghost" href="?route=connexion">Accéder à mon espace</a>
            </div>

            <div class="hero__badges">
                <span class="badge">Stage</span>
                <span class="badge">Wish-list</span>
                <span class="badge">Suivi candidature</span>
                <span class="badge">Pilote de promo</span>
            </div>

            <div class="hero__mini-proof">
                <div class="mini-proof">
                    <strong>Recherche centralisée</strong>
                    <span>Consultez les offres, les entreprises et le suivi des candidatures depuis une seule plateforme.</span>
                </div>
                <div class="mini-proof mini-proof--accent">
                    <strong>Suivi par profil</strong>
                    <span>Chaque utilisateur accède aux informations utiles selon son rôle.</span>
                </div>
            </div>
        </div>

        <aside class="search-panel">
            <div class="search-panel__head">
                <p class="search-panel__eyebrow">Recherche rapide</p>
                <h2>Rechercher une offre</h2>
            </div>

            <form class="search search--hello" method="get" action="">
                <input type="hidden" name="route" value="offres_stage">

                <label class="field field--search">
                    <span class="field__label">Quoi ?</span>
                    <input class="input" name="keyword" type="text" placeholder="Métier, compétence, entreprise">
                </label>

                <label class="field field--search">
                    <span class="field__label">Où ?</span>
                    <input class="input" name="location" type="text" placeholder="Ville, département">
                </label>

                <button class="btn btn--primary btn--search search__submit" type="submit">
                    <span class="btn__icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" role="img" focusable="false">
                            <path d="M10.5 4a6.5 6.5 0 1 0 4.03 11.6l4.44 4.43 1.41-1.41-4.43-4.44A6.5 6.5 0 0 0 10.5 4Zm0 2a4.5 4.5 0 1 1 0 9 4.5 4.5 0 0 1 0-9Z" fill="currentColor"/>
                        </svg>
                    </span>
                    <span>Rechercher</span>
                </button>
            </form>

            <div class="chips">
                {% for search in popularSearches %}
                    <a class="chip" href="?route=offres_stage">{{ search }}</a>
                {% endfor %}
            </div>

            <div class="search-panel__footer">
                <p class="search-panel__hint">Renseignez un mot-clé et, si besoin, une ville.</p>
            </div>
        </aside>
    </div>
</section>

<section class="metrics-band">
    <div class="container metrics-grid">
        {% for stat in siteStats %}
            <article class="metric-card">
                <strong>{{ stat.value }}</strong>
                <span>{{ stat.label }}</span>
            </article>
        {% endfor %}
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="section__head section__head--compact">
            <h2>Fonctionnalités principales</h2>
            <p class="muted">Les principaux services disponibles pour les étudiants et les pilotes.</p>
        </div>

        <div class="cards cards--three">
            {% for benefit in benefits %}
                <article class="card card--benefit">
                    <div class="benefit-mark"></div>
                    <h3>{{ benefit.title }}</h3>
                    <p class="muted">{{ benefit.description }}</p>
                </article>
            {% endfor %}
        </div>
    </div>
</section>

<section class="section section--surface">
    <div class="container">
        <div class="section__head">
            <h2>Accès par profil</h2>
            <p class="muted">Chaque profil dispose d’un espace adapté à ses besoins.</p>
        </div>

        <div class="cards cards--three">
            {% for profile in profiles %}
                <article class="card card--feature">
                    <p class="card__eyebrow">Espace dedie</p>
                    <h3>{{ profile.title }}</h3>
                    <p class="muted">{{ profile.description }}</p>
                    <a class="link" href="?route={{ profile.cta_route }}">{{ profile.cta_label }}</a>
                </article>
            {% endfor %}
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="section__head">
            <h2>Offres récentes</h2>
            <p class="muted">Consultez rapidement les offres mises en avant.</p>
        </div>

        {% if offresMisesEnAvant is not empty %}
            <div class="list">
                {% for offre_stage in offresMisesEnAvant %}
                    <article class="list__item">
                        <div class="list__body">
                            <div class="list__title">{{ offre_stage.title }}</div>
                            <div class="list__meta">
                                <span>{{ offre_stage.company }}</span>
                                <span>{{ offre_stage.location }}</span>
                                <span>Stage</span>
                                <span>{{ offre_stage.duration_weeks }} semaines</span>
                                {% if offre_stage.salary %}
                                    <span>{{ offre_stage.salary }}</span>
                                {% endif %}
                            </div>
                        </div>
                        <a class="btn btn--small" href="?route=offre_stage&id={{ offre_stage.id }}">Voir</a>
                    </article>
                {% endfor %}
            </div>
        {% else %}
            <p>Aucune offre mise en avant pour le moment.</p>
        {% endif %}

        <div class="section__foot">
            <a class="btn btn--ghost" href="?route=offres_stage">Voir toutes les offres</a>
        </div>
    </div>
</section>

<section class="section section--surface">
    <div class="container">
        <div class="section__head">
            <h2>Entreprises à suivre</h2>
            <p class="muted">Quelques entreprises actuellement mises en avant sur la plateforme.</p>
        </div>

        <div class="cards">
            {% for company in featuredCompanies %}
                <article class="card card--company">
                    <div class="company-card__top">
                        <div class="company-badge">{{ company.name|slice(0, 2)|upper }}</div>
                        <p class="company-rating">{{ company.rating }}</p>
                    </div>
                    <h3>{{ company.name }}</h3>
                    <p class="muted">{{ company.sector }}</p>
                    <p>{{ company.summary }}</p>
                    <a class="link" href="?route=entreprise_show&id={{ company.id }}">Voir la fiche</a>
                </article>
            {% endfor %}
        </div>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="section__head">
            <h2>Parcours utilisateur</h2>
            <p class="muted">Naviguez simplement dans le flux principal.</p>
        </div>

        <ol class="timeline">
            {% for step in processSteps %}
                <li class="timeline__item">{{ step }}</li>
            {% endfor %}
        </ol>
    </div>
</section>

<section class="cta" id="cta">
    <div class="container cta__box">
        <div>
            <h2>Accéder à la plateforme</h2>
            <p class="muted">
                Connectez-vous pour consulter votre espace personnel.
            </p>
        </div>
        <a class="btn btn--primary" href="?route=connexion">Accéder à la plateforme</a>
    </div>
</section>
{% endblock %}
