{% extends 'base/mise-en-page.html.twig' %}

{% block pageTitle %}
<title>{{ page_title }}</title>
{% endblock %}

{% block content %}
<section class="section">
    <div class="container">
        <div class="section__head">
            <h1>Statistiques des offres</h1>
            <p class="muted">Consultez les principaux indicateurs liés aux offres de stage.</p>
        </div>

        <div class="stats-carousel">
            <article class="card stats-card">
                <p class="stats-card__eyebrow">Offres disponibles</p>
                <strong class="stats-card__value">{{ stats.total_offres }}</strong>
                <p class="muted">Nombre total d’offres actuellement enregistrées en base.</p>
            </article>

            <article class="card stats-card">
                <p class="stats-card__eyebrow">Candidatures</p>
                <strong class="stats-card__value">{{ stats.average_candidatures }}</strong>
                <p class="muted">Nombre moyen de candidatures par offre.</p>
            </article>

            <article class="card stats-card stats-card--wide">
                <p class="stats-card__eyebrow">Top wishlist</p>
                <strong class="stats-card__value">Top {{ stats.wishlist_top|length }}</strong>
                {% if stats.wishlist_top is not empty %}
                    <ul class="stats-list">
                        {% for offre in stats.wishlist_top %}
                            <li>
                                <span>{{ offre.title }} - {{ offre.company }}</span>
                                <strong>{{ offre.wishlist_count }}</strong>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <p class="muted">Aucune donnée de wishlist n’est disponible pour le moment.</p>
                {% endif %}
            </article>

            <article class="card stats-card stats-card--wide">
                <p class="stats-card__eyebrow">Répartition par durée</p>
                <strong class="stats-card__value">{{ stats.durations|length }}</strong>
                {% if stats.durations is not empty %}
                    <ul class="stats-list">
                        {% for item in stats.durations %}
                            <li>
                                <span>{{ item.duration_weeks }} semaine{% if item.duration_weeks > 1 %}s{% endif %}</span>
                                <strong>{{ item.offers_count }}</strong>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <p class="muted">Aucune offre n’est encore disponible.</p>
                {% endif %}
            </article>
        </div>
    </div>
</section>
{% endblock %}
