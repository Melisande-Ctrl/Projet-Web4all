{% extends 'base/layout.html.twig' %}

{% block pageTitle %}
<title>{{ page_title }}</title>
{% endblock %}

{% block content %}
<section class="section">
    <div class="container">
        <div class="section__head">
            <h1>Offres de stage</h1>
            <p class="muted">Base de listing qui accueillera ensuite les filtres et la pagination.</p>
        </div>

        {% if internships is not empty %}
            <div class="list">
                {% for internship in internships %}
                    <article class="list__item">
                        <div>
                            <div class="list__title">{{ internship.title }}</div>
                            <div class="muted">
                                {{ internship.company }} • {{ internship.location }} • {{ internship.salary }}
                            </div>
                        </div>
                        <a class="btn btn--small" href="?route=internship_show&id={{ internship.id }}">Voir le detail</a>
                    </article>
                {% endfor %}
            </div>
        {% else %}
            <p>Aucune offre disponible.</p>
        {% endif %}
    </div>
</section>
{% endblock %}
