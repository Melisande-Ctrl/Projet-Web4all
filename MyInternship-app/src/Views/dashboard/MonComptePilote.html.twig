{% extends "dashboard/layout_dashboard.html.twig" %}

{% block dashboard_content %}

    {% if section == 'etudiants' %}

        <div class="card">
            <h3>Liste des étudiants</h3>
            <p>À venir...</p>
        </div>

    {% elseif section == 'offres' %}

        <div class="card">
            <h3>Offres de stage</h3>
            <p class="muted">Consultez les statistiques globales liées aux offres et aux candidatures.</p>
            <a class="btn btn--primary" href="?route=offres_stage_stats">Voir les statistiques des offres</a>
        </div>

    {% endif %}

{% endblock %}
