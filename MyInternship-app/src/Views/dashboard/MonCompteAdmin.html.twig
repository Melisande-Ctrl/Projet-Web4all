{% extends "dashboard/layout_dashboard.html.twig" %}

{% block dashboard_content %}

    {% if section == 'users' %}

        <div class="card">
            <h3>Gestion des utilisateurs</h3>
            <p>À venir...</p>
        </div>

    {% elseif section == 'entreprises' %}

        <div class="card">
            <h3>Créer une entreprise </h3>
            <form method="POST" action="?route=new_entreprise">
                <div class="form-grid">
                    <div class="field">
                        <label class="field__label">Nom</label>
                        <input class="input" type="text" placeholder="Ex : Nike" name="Nom" minlength="1" maxlength="150" required >
                    </div>

                    <div class="field">
                        <label class="field__label">Description</label>
                        <input class="input" type="text" placeholder="Ex : ESN..." name="Description" minlength="5" required>
                    </div>

                    <div class="field">
                        <label class="field__label">Email</label>
                        <input class="input" type="email" placeholder="Ex : entreprise@nike.com" name="Email" minlength="5" maxlength="50" required>
                    </div>

                    <div class="field">
                        <label class="field__label">Telephone</label>
                        <input class="input" type="" placeholder="Ex : 0784156478" name="Telephone" pattern="[0-9]+" minlength="10" maxlength="20" required>
                    </div>

                    <div class="field">
                        <label class="field__label">Adresse</label>
                        <input class="input" type="text" placeholder="Ex : 56 Rue du château" name="Adresse" minlength="1" maxlength="100" required>
                    </div>

                    <div class="field">
                        <label class="field__label">Ville</label>
                        <input class="input" type="text" placeholder="Ex : La Rochelle" name="Ville" pattern="[A-Za-zÀ-ÿ\- ]+" minlength="1" maxlength="60" required>
                    </div>

                    <div class="field">
                        <label class="field__label">Pays</label>
                        <input class="input" type="text" placeholder="Ex : France" name="Pays" pattern="[A-Za-zÀ-ÿ\- ]+" minlength="1" maxlength="50" required>
                    </div>
                </div>

                <div style="margin-top:20px;">
                    <button class="btn btn--primary" type="submit">
                        Créer cette entreprise
                    </button>
                </div>
            </form>
        </div>

    {% elseif section == 'stats' %}

        <div class="card">
            <h3>Statistiques</h3>
            <p class="muted">Consultez les principaux indicateurs liés aux offres de stage.</p>
            <a class="btn btn--primary" href="?route=offres_stage_stats">Voir les statistiques des offres</a>
        </div>

    {% endif %}

{% endblock %}
