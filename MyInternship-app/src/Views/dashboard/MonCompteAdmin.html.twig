{% extends "dashboard/layout_dashboard.html.twig" %}

{% block dashboard_content %}

    {% if section == 'infos' %}

        <div class="card form-card">
            <h3>Informations du compte</h3>

            <div class="form-grid">
                <div class="field">
                    <label class="field__label">Nom</label>
                    <input class="input" value="{{ session.user.nom }}" disabled>
                </div>

                <div class="field">
                    <label class="field__label">Prénom</label>
                    <input class="input" value="{{ session.user.prenom }}" disabled>
                </div>

                <div class="field">
                    <label class="field__label">Email</label>
                    <input class="input" value="{{ session.user.email }}" disabled>
                </div>

                <div class="field">
                    <label class="field__label">Mot de passe</label>

                    <div style="display:flex; gap:10px; align-items:center;">
                        <input class="input" type="password" value="********" disabled>

                        <a href="?route=admin_dashboard&section=password"
                           class="btn btn--ghost btn--small">
                            Modifier le mot de passe
                        </a>
                    </div>
                </div>
            </div>
        </div>


    {% elseif section == 'entreprises' %}

        <div class="card">
            <h3>Créer une entreprise </h3>
            <form method="POST" action="?route=new_entreprise">
                <div class="form-grid">
                    <div class="field">
                        <label class="field__label">Nom</label>
                        <input class="input" type="text" placeholder="Ex : Nike" name="Nom" minlength="1" maxlength="150" required >
                    </div>

                    <div class="field">
                        <label class="field__label">Description</label>
                        <input class="input" type="text" placeholder="Ex : ESN..." name="Description" minlength="5" required>
                    </div>

                    <div class="field">
                        <label class="field__label">Email</label>
                        <input class="input" type="email" placeholder="Ex : entreprise@nike.com" name="Email" minlength="5" maxlength="50" required>
                    </div>

                    <div class="field">
                        <label class="field__label">Telephone</label>
                        <input class="input" type="" placeholder="Ex : 0784156478" name="Telephone" pattern="[0-9]+" minlength="10" maxlength="20" required>
                    </div>

                    <div class="field">
                        <label class="field__label">Adresse</label>
                        <input class="input" type="text" placeholder="Ex : 56 Rue du château" name="Adresse" minlength="1" maxlength="100" required>
                    </div>

                    <div class="field">
                        <label class="field__label">Ville</label>
                        <input class="input" type="text" placeholder="Ex : La Rochelle" name="Ville" pattern="[A-Za-zÀ-ÿ\- ]+" minlength="1" maxlength="60" required>
                    </div>

                    <div class="field">
                        <label class="field__label">Pays</label>
                        <input class="input" type="text" placeholder="Ex : France" name="Pays" pattern="[A-Za-zÀ-ÿ\- ]+" minlength="1" maxlength="50" required>
                    </div>
                </div>

                <div style="margin-top:20px;">
                    <button class="btn btn--primary" type="submit">
                        Créer cette entreprise
                    </button>
                </div>
            </form>
        </div>

    {% elseif section == 'etudiants' %}

        <form method="GET" action="">
            <input type="hidden" name="route" value="admin_dashboard">
            <input type="hidden" name="section" value="etudiants">

            <label class="field">
                <span class="field__label">Rechercher un étudiant</span>
                <input
                        class="input"
                        name="nom"
                        type="text"
                        placeholder="Nom"
                        value="{{ app.request.get('nom') }}"
                >
            </label>
        </form>

        {% if etudiants is defined and etudiants is not empty %}
            <div class="card" style="margin-top:20px;">
                <h3>Résultats</h3>

                <div class="list">
                    {% for etudiant in etudiants %}
                        <div class="list__item">

                            <div class="list__body">
                                <div class="list__title">
                                    {{ etudiant.Nom }} {{ etudiant.Prenom }}
                                </div>

                                <div class="list__meta">
                                    <span>{{ etudiant.Email }}</span>
                                </div>
                            </div>



                        </div>
                    {% endfor %}
                </div>
            </div>

        {% elseif etudiants is defined %}
            <div class="empty-state">
                <p>Aucun étudiant trouvé</p>
            </div>
        {% endif %}

    {% elseif section == 'password' %}

        <div class="card form-card">
            <h3>Changer le mot de passe</h3>

            <form method="POST" action="?route=change_password">
                <div class="form-grid">
                    <div class="field">
                        <label class="field__label">Mot de passe actuel</label>
                        <input class="input" type="password" name="current_password" required>
                    </div>

                    <div class="field">
                        <label class="field__label">Nouveau mot de passe</label>
                        <input class="input" type="password" name="new_password" required>
                    </div>

                    <div class="field">
                        <label class="field__label">Confirmer le mot de passe</label>
                        <input class="input" type="password" name="confirm_password" required>
                    </div>
                </div>

                <div style="margin-top:20px;">
                    <button class="btn btn--primary" type="submit">
                        Mettre à jour le mot de passe
                    </button>
                </div>
            </form>
        </div>



    {% endif %}

{% endblock %}
