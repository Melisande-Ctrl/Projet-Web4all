{% extends 'base/layout.html.twig' %}

{% block pageTitle %}
<title>{{ page_title }}</title>
{% endblock %}

{% block content %}
<section class="section">
    <div class="container">
        <div class="section__head">
            <h1>Entreprises partenaires</h1>
            <p class="muted">Base de travail pour la future recherche multicritere des entreprises.</p>
        </div>

        {% if companies is not empty %}
            <div class="cards">
                {% for company in companies %}
                    <article class="card">
                        <h3>{{ company.name }}</h3>
                        <p class="muted">{{ company.sector }} • note moyenne {{ company.rating }}</p>
                        <a class="link" href="?route=entreprise_show&id={{ company.id }}">Voir la fiche</a>
                    </article>
                {% endfor %}
            </div>
        {% else %}
            <p>Aucune entreprise n est disponible.</p>
        {% endif %}
    </div>
</section>
{% endblock %}
