{% extends 'base/layout.html.twig' %}

{% block content %}
<section>
    <h1>Entreprises partenaires</h1>
    <p>Cette page preparera ensuite la recherche multicritere des entreprises.</p>

    {% if companies is not empty %}
        <ul>
            {% for company in companies %}
                <li>
                    <strong>{{ company.name }}</strong> - {{ company.sector }} - note moyenne : {{ company.rating }}
                    <a href="?route=entreprise_show&id={{ company.id }}">Voir la fiche</a>
                </li>
            {% endfor %}
        </ul>
    {% else %}
        <p>Aucune entreprise n'est disponible.</p>
    {% endif %}
</section>
{% endblock %}
